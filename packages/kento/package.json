{
  "name": "kento",
  "version": "0.1.0-beta.0",
  "description": "Kento - a Koa-like multi-runtime web framework (beta)",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./runtime-bun": "./src/runtime-bun.ts",
    "./runtime-node": "./src/runtime-node.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run --watch src/index.ts"
  },
  "dependencies": {
    "@kento/bodyparser": "workspace:*",
    "@kento/compress": "workspace:*",
    "@kento/core": "workspace:*",
    "@kento/cors": "workspace:*",
    "@kento/helmet": "workspace:*",
    "@kento/logger": "workspace:*",
    "@kento/ratelimit": "workspace:*",
    "@kento/router": "workspace:*",
    "@kento/runtime-bun": "workspace:*",
    "@kento/runtime-node": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  }
}
