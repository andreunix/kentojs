{
    "name": "kento-framework",
    "version": "0.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "typecheck:all": "bun run --filter '*' typecheck",
        "test": "bun test",
        "test:all": "bun run --filter '*' test",
        "example:hello": "bun run examples/hello-world.ts",
        "dev": "bun run --cwd packages/kento --watch src/index.ts",
        "build": "bun run --filter '*' build"
    },
    "dependencies": {
        "kento": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^6.0.2"
    }
}
